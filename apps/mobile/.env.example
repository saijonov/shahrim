# Copy to .env — Expo automatically loads .env and inlines EXPO_PUBLIC_* vars.
# Never commit real secrets. These two are the only client config the app needs.

# Backend API base URL. No trailing slash — the app appends paths directly
# (e.g. `${EXPO_PUBLIC_API_URL}/issues`), NOT `/api`.
# For a physical phone in Expo Go, use a public HTTPS tunnel (e.g. cloudflared,
# ngrok) pointing at the backend, e.g. https://abcd-1234.trycloudflare.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# Telegram bot username (without @). Used to build the login deep link
# https://t.me/<username>?start=login_<nonce>
EXPO_PUBLIC_BOT_USERNAME=ShahrimSamarqandBot
