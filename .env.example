# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# ---- App ----
APP_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ---- Database (Postgres + PostGIS) ----
# These POSTGRES_* values are consumed by the `db` service in docker-compose.
POSTGRES_USER=shahrim
POSTGRES_PASSWORD=shahrim
POSTGRES_DB=shahrim
# The backend connects with this URL (psycopg3 driver, works sync + async).
DATABASE_URL=postgresql+psycopg://shahrim:shahrim@db:5432/shahrim

# ---- Storage (Phase 2) ----
# Local filesystem for now; behind a Storage interface so S3 can drop in later.
UPLOAD_DIR=/app/uploads
PUBLIC_BASE_URL=http://localhost:8000

# ---- Telegram (Phase 1) ----
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL where the Mini App is served (e.g. a cloudflared tunnel).
MINIAPP_URL=

# ---- AI / OpenAI (Phase 3) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Admin portal (Phase 5) ----
# An admin account is created/updated on backend startup from these.
ADMIN_EMAIL=admin@shahrim.uz
ADMIN_PASSWORD=change-me


# ---- CORS (comma-separated origins allowed to call the API) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
